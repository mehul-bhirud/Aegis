# ═══════════════════════════════════════════════════
#  AEGIS-FUSION .gitignore
# ═══════════════════════════════════════════════════

# ── Large Data Files (exceed GitHub 100MB limit) ──
data/enterprise_activity_stream.jsonl
data/test_anomalies.jsonl

# ── Python ──
__pycache__/
*.pyc
*.pyo
.env
.venv/
env/
venv/

# ── PyTorch artifacts ──
ml/models/*.pth
ml/data/*.pt

# ── Node / Next.js ──
frontend/node_modules/
frontend/.next/
frontend/out/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── OS junk ──
.DS_Store
Thumbs.db
desktop.ini
